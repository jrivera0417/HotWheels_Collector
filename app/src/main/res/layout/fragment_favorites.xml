<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ========================= -->
        <!-- EMPTY STATE -->
        <!-- ========================= -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="28dp"
            android:background="@drawable/bg_glass_card"
            android:layout_margin="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="220dp"
                android:layout_height="150dp"
                android:src="@drawable/ic_hotwheels_empty"
                android:scaleType="fitCenter"
                android:alpha="0.95"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tus favoritos están vacios"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.03"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agrega Hot Wheels a tus favoritos y construye tu vitrina"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:alpha="0.85"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFav"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:text="Explorar colección"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:layout_marginTop="22dp"
                android:paddingHorizontal="26dp"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/primary"
                app:elevation="8dp"
                app:rippleColor="@android:color/white"/>

        </LinearLayout>

        <!-- ========================= -->
        <!-- FAVORITES GRID -->
        <!-- ========================= -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFavorites"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:clipToPadding="false"
            android:padding="12dp"
            android:paddingBottom="90dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>